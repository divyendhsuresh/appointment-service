<?xml version="1.0" encoding="UTF-8"?>

<configuration>

    <!-- Read values from Spring configuration/environment -->

    <springProperty
            scope="context"
            name="SERVICE_NAME"
            source="spring.application.name"
            defaultValue="booking-service"/>

    <springProperty
            scope="context"
            name="ROOT_LOG_LEVEL"
            source="logging.level.root"
            defaultValue="INFO"/>

    <!--
        Local execution:
        ./logs/booking-service

        Docker:
        LOG_PATH=/app/logs
    -->
    <property
            name="LOG_PATH"
            value="${LOG_PATH:-./logs/booking-service}"/>

    <property
            name="CONSOLE_PATTERN"
            value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] [transactionId=%X{transactionId:-N/A}] [%logger{36}] - %msg%n"/>

    <property
            name="FILE_PATTERN"
            value="%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} %-5level service=${SERVICE_NAME} thread=%thread transactionId=%X{transactionId:-N/A} logger=%logger{50} - %msg%n"/>

    <!-- Console output -->

    <appender
            name="CONSOLE"
            class="ch.qos.logback.core.ConsoleAppender">

        <encoder>
            <charset>UTF-8</charset>
            <pattern>${CONSOLE_PATTERN}</pattern>
        </encoder>

    </appender>

    <!-- Main booking-service log -->

    <appender
            name="BOOKING_FILE"
            class="ch.qos.logback.core.rolling.RollingFileAppender">

        <file>${LOG_PATH}/booking-service.log</file>

        <rollingPolicy
                class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">

            <fileNamePattern>
                ${LOG_PATH}/archived/booking-service.%d{yyyy-MM-dd}.%i.log.gz
            </fileNamePattern>

            <maxFileSize>20MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>2GB</totalSizeCap>

            <cleanHistoryOnStart>true</cleanHistoryOnStart>

        </rollingPolicy>

        <encoder>
            <charset>UTF-8</charset>
            <pattern>${FILE_PATTERN}</pattern>
        </encoder>

    </appender>

    <!-- Kafka producer/application event log -->

    <appender
            name="KAFKA_EVENT_FILE"
            class="ch.qos.logback.core.rolling.RollingFileAppender">

        <file>${LOG_PATH}/kafka-events.log</file>

        <rollingPolicy
                class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">

            <fileNamePattern>
                ${LOG_PATH}/archived/kafka-events.%d{yyyy-MM-dd}.%i.log.gz
            </fileNamePattern>

            <maxFileSize>20MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>

            <cleanHistoryOnStart>true</cleanHistoryOnStart>

        </rollingPolicy>

        <encoder>
            <charset>UTF-8</charset>
            <pattern>${FILE_PATTERN}</pattern>
        </encoder>

    </appender>

    <!-- Error-only log -->

    <appender
            name="ERROR_FILE"
            class="ch.qos.logback.core.rolling.RollingFileAppender">

        <file>${LOG_PATH}/errors.log</file>

        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>

        <rollingPolicy
                class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">

            <fileNamePattern>
                ${LOG_PATH}/archived/errors.%d{yyyy-MM-dd}.%i.log.gz
            </fileNamePattern>

            <maxFileSize>20MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>

        </rollingPolicy>

        <encoder>
            <charset>UTF-8</charset>
            <pattern>${FILE_PATTERN}</pattern>
        </encoder>

    </appender>

    <!--
        Everything inside this package goes to kafka-events.log.

        Change the package if your producer classes are in another package.
    -->
    <logger
            name="com.mykare.appointment_service.Kafka"
            level="INFO"
            additivity="false">

        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="KAFKA_EVENT_FILE"/>
        <appender-ref ref="ERROR_FILE"/>

    </logger>

    <!-- Reduce noisy framework logs -->

    <logger name="org.apache.kafka" level="WARN"/>
    <logger name="org.springframework.kafka" level="INFO"/>
    <logger name="org.hibernate.SQL" level="WARN"/>
    <logger name="org.hibernate.orm.jdbc.bind" level="WARN"/>
    <logger name="org.springframework.web" level="INFO"/>

    <!-- All other application logs -->

    <root level="${ROOT_LOG_LEVEL}">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="BOOKING_FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </root>

</configuration>